# =============================================================================
# MyVineOS – environment template
# =============================================================================
# Copy this file to `.env` and fill in real values for your machine/host:
#   cp .env.example .env
#
# NEVER commit `.env` — it is gitignored.
# Values below are PLACEHOLDERS only (safe for a public repo).

# ─── MariaDB / MySQL ─────────────────────────────────────────────────────────
MYSQL_HOST=127.0.0.1
MYSQL_USER=churchuser
MYSQL_PASSWORD=change-me-db-password
MYSQL_DATABASE=church_management
# Local docker-compose maps host 3308 → container 3306
MYSQL_PORT=3308

# ─── App security (REQUIRED in production) ───────────────────────────────────
# Generate strong values, for example:
#   python -c "import secrets; print(secrets.token_hex(32))"
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
SECRET_KEY=change-me-to-a-long-random-string
FERNET_KEY=change-me-use-Fernet.generate_key

# ─── Server ──────────────────────────────────────────────────────────────────
DEBUG_MODE=false
HOST=0.0.0.0
PORT=5001

# ─── Optional mail (often stored encrypted in DB settings UI) ────────────────
# MAIL_SERVER=smtp.example.com
# MAIL_PORT=587
# MAIL_USE_TLS=true
# MAIL_USERNAME=
# MAIL_PASSWORD=

# --- PoweredByTop / church security ---
# Production behind HTTPS: REQUIRE_HTTPS=true
# Local or HTTP reverse-proxy without X-Forwarded-Proto: REQUIRE_HTTPS=false
REQUIRE_HTTPS=false
PBT_BIND_SESSION_TO_IP=false
